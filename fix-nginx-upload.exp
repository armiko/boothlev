send "7bTMT5NR\r"
expect eof

spawn ssh -p 1757 -o StrictHostKeyChecking=no root@154.12.118.208 "pm2 status && /etc/init.d/nginx restart"
expect "password:"
send "7bTMT5NR\r"
expect eof
